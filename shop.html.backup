<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shop — Work Brings Freedom</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&family=Playfair+Display:wght@900&family=Bebas+Neue&family=Special+Elite&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #111111;
    --paper: #f3ecd8;
    --blood: #c8102e;
    --blood-dark: #8b0a1f;
    --cream: #e8dec1;
    --rule: #1a1a1a;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: var(--paper); color: var(--ink); font-family: "IBM Plex Mono", monospace; }
  body.lock { overflow: hidden; }

  .caution {
    background: repeating-linear-gradient(135deg, #111 0 18px, #ffd100 18px 36px);
    height: 18px; width: 100%;
  }

  nav {
    background: var(--ink); color: var(--paper);
    padding: 18px 40px; display: flex; align-items: center; justify-content: space-between;
    border-bottom: 3px solid var(--blood);
  }
  nav .logo {
    font-family: "Bebas Neue", sans-serif; font-size: 30px; letter-spacing: 3px;
    display: flex; align-items: center; gap: 10px;
  }
  nav .logo .mark {
    background: var(--blood); color: var(--paper); padding: 2px 10px; transform: rotate(-2deg);
    border: 2px solid var(--paper); box-shadow: 3px 3px 0 var(--paper);
  }
  nav ul { list-style: none; display: flex; gap: 30px; }
  nav ul a {
    color: var(--paper); text-decoration: none; font-family: "IBM Plex Mono", monospace;
    font-size: 13px; text-transform: uppercase; letter-spacing: 2px; padding: 6px 2px;
    border-bottom: 2px solid transparent; transition: all .15s;
  }
  nav ul a:hover, nav ul a.active { color: var(--blood); border-bottom-color: var(--blood); }
  nav .tools { display: flex; gap: 14px; align-items: center; }
  nav .tools button {
    background: transparent; color: var(--paper); border: 1px solid var(--paper);
    padding: 8px 14px; font-family: "IBM Plex Mono", monospace; font-size: 12px;
    text-transform: uppercase; letter-spacing: 2px; cursor: pointer; transition: all .15s;
  }
  nav .tools button:hover { background: var(--blood); border-color: var(--blood); }

  .page-header {
    background: var(--ink); color: var(--paper); padding: 60px 40px;
    text-align: center; position: relative; overflow: hidden;
  }
  .page-header h1 {
    font-family: "Playfair Display", serif; font-weight: 900; font-size: clamp(40px, 6vw, 80px);
    letter-spacing: -2px; position: relative; z-index: 2;
  }
  .page-header p {
    font-size: 15px; color: #dcd5c0; max-width: 600px; margin: 16px auto 0;
    position: relative; z-index: 2;
  }

  .filters {
    padding: 30px 40px; background: var(--cream); border-bottom: 2px solid var(--ink);
  }
  .filters-inner { max-width: 1400px; margin: 0 auto; display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
  .filters .label {
    font-family: "Special Elite", cursive; font-size: 13px; text-transform: uppercase;
    letter-spacing: 2px; margin-right: 8px;
  }
  .chip {
    background: transparent; border: 2px solid var(--ink); padding: 8px 14px; cursor: pointer;
    font-family: "IBM Plex Mono", monospace; font-size: 12px; text-transform: uppercase;
    letter-spacing: 1.5px; transition: all .15s;
  }
  .chip:hover, .chip.active { background: var(--ink); color: var(--paper); }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 30px; padding: 40px; max-width: 1400px; margin: 0 auto; }
  .book { cursor: pointer; }
  .book:hover { transform: translateY(-4px); }
  .book .cover {
    aspect-ratio: 2/3; background: var(--ink); position: relative; overflow: hidden;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    padding: 20px; border: 2px solid var(--ink);
  }
  .book .cover img {
    width: 100%; height: 100%; object-fit: cover; display: block; border: none;
  }
  .book .cover .title-area {
    font-family: "Playfair Display", serif; font-weight: 900; font-size: 18px;
    color: var(--paper); text-align: center; line-height: 1.2;
  }
  .book .cover .author {
    font-size: 11px; color: var(--blood); margin-top: 10px; letter-spacing: 1px;
  }
  .book .info { padding-top: 14px; }
  .book .info .t { font-family: "Playfair Display", serif; font-weight: 700; font-size: 17px; line-height: 1.2; margin-bottom: 4px; }
  .book .info .a { font-size: 12px; opacity: 0.75; }

  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 100; display: none; align-items: center; justify-content: center; padding: 20px; }
  .modal-overlay.open { display: flex; }
  .modal-inner { background: var(--paper); max-width: 800px; width: 100%; max-height: 90vh; overflow-y: auto; display: grid; grid-template-columns: 1fr 1.2fr; position: relative; border: 3px solid var(--ink); }
  .modal .cover-area { background: var(--ink); padding: 40px; display: flex; align-items: center; justify-content: center; }
  .modal .cover-area .cover { width: 100%; max-width: 220px; aspect-ratio: 2/3; }
  .modal .body { padding: 30px; }
  .modal .body h2 { font-family: "Playfair Display", serif; font-size: 28px; margin-bottom: 8px; }
  .modal .body .meta { font-size: 13px; opacity: 0.7; margin-bottom: 16px; }
  .modal .body .price { font-family: "Bebas Neue", sans-serif; font-size: 28px; color: var(--blood); }
  .modal .body .blurb { font-size: 14px; line-height: 1.6; margin: 16px 0; }
  .modal .body .reason { font-size: 12px; border-left: 3px solid var(--blood); padding-left: 12px; margin-bottom: 20px; }
  .modal .body .actions { display: flex; gap: 12px; }
  .modal .body .actions button {
    flex: 1; padding: 14px; font-family: "Bebas Neue", sans-serif; font-size: 16px;
    letter-spacing: 2px; text-transform: uppercase; cursor: pointer; border: 2px solid var(--ink);
  }
  .modal .body .actions .add { background: var(--blood); color: var(--paper); border-color: var(--blood); }
  .modal .body .actions .add:hover { background: var(--ink); }
  .modal .close { position: absolute; top: 10px; right: 14px; background: none; border: none; font-size: 28px; cursor: pointer; color: var(--ink); }

  footer { background: var(--ink); color: var(--paper); padding: 50px 40px 30px; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; max-width: 1400px; margin: 0 auto; }
  footer h4 { font-family: "Bebas Neue", sans-serif; font-size: 20px; letter-spacing: 3px; margin-bottom: 16px; }
  footer a { color: var(--paper); text-decoration: none; font-size: 13px; display: block; margin-bottom: 8px; opacity: 0.8; }
  footer a:hover { color: var(--blood); }
  footer .brand-blurb { font-size: 13px; line-height: 1.6; opacity: 0.75; max-width: 360px; }
  footer ul { list-style: none; }
  footer ul li { margin-bottom: 8px; }
  footer ul a { color: var(--paper); text-decoration: none; opacity: 0.8; }
  footer ul a:hover { color: var(--blood); }
  .footer-bottom { border-top: 1px solid #333; padding-top: 20px; display: flex; justify-content: space-between; font-size: 11px; opacity: 0.6; letter-spacing: 1px; text-transform: uppercase; }

  .toast {
    position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(100px);
    background: var(--ink); color: var(--paper); padding: 14px 28px;
    font-family: "IBM Plex Mono", monospace; font-size: 13px; letter-spacing: 2px;
    text-transform: uppercase; z-index: 300; opacity: 0; transition: all .3s ease;
    border: 2px solid var(--blood);
  }
  .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
</style>
</head>
<body>
<div class="caution"></div>

<nav>
  <div class="logo"><span class="mark">WBF</span> <span>WORK BRINGS FREEDOM</span></div>
  <ul>
    <li><a href="shop.html" class="active">Shop</a></li>
    <li><a href="collections.html">Collections</a></li>
    <li><a href="ourstory.html">Our Story</a></li>
    <li><a href="join.html">Join</a></li>
  </ul>
  <div class="tools">
    <button onclick="location.href='index.html'">Home</button>
  </div>
</nav>

<section class="page-header">
  <h1>The Library</h1>
  <p>1116 forbidden books they didn't want you to read. Each one challenged, censored, or banned — and every one essential.</p>
</section>

<section class="filters">
  <div class="filters-inner">
    <span class="label">Filter:</span>
    <button class="chip active" data-filter="all">All</button>
    <button class="chip" data-filter="politics">Politics</button>
    <button class="chip" data-filter="philosophy">Philosophy</button>
    <button class="chip" data-filter="history">History</button>
    <button class="chip" data-filter="sociology">Sociology</button>
  </div>
</section>

<div class="grid" id="productGrid"></div>

<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
  <div class="modal-inner">
    <button class="close" onclick="closeModal()">&times;</button>
    <div class="cover-area"><div class="cover" id="modalCover"></div></div>
    <div class="body" id="modalBody"></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<footer>
  <div class="footer-grid">
    <div>
      <h4>Work Brings Freedom</h4>
      <p class="brand-blurb">A movement built on the principle that knowledge creates liberty. We curate banned, challenged, and forbidden books — the ones they didn't want you to read. Because the most dangerous thing in the world is a mind that thinks for itself.</p>
    </div>
    <div>
      <h4>Shop</h4>
      <ul>
        <li><a href="shop.html">All Books</a></li>
        <li><a href="collections.html">Collections</a></li>
        <li><a href="shop.html">Politics</a></li>
        <li><a href="shop.html">Philosophy</a></li>
      </ul>
    </div>
    <div>
      <h4>Learn</h4>
      <ul>
        <li><a href="ourstory.html">Our Story</a></li>
        <li><a href="ourstory.html#manifesto">The Manifesto</a></li>
        <li><a href="join.html">Blog</a></li>
        <li><a href="join.html">Community</a></li>
      </ul>
    </div>
    <div>
      <h4>Connect</h4>
      <ul>
        <li><a href="https://www.youtube.com/@workbringsfreedom" target="_blank">YouTube</a></li>
        <li><a href="https://www.tiktok.com/@workbringsfreedom" target="_blank">TikTok</a></li>
        <li><a href="https://www.instagram.com/workbringsfreedom/" target="_blank">Instagram</a></li>
        <li><a href="https://workbringsfreedom.substack.com" target="_blank">Substack</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <div>&copy; 2026 Work Brings Freedom &mdash; Built by Grind</div>
    <div>/ No Excuses. No Regrets. /</div>
  </div>
</footer>

<script>
const PRODUCTS = [
{   id:1, title:"The Death of the West", author:"Patrick J. Buchanan", year:2002, cat:"politics", price:22.00, coverImage:"covers/deathofwest.jpg", freeLink:"https://archive.org/details/deathofwesthowdy0000buch", freeLink:"https://archive.org/details/we00zami/page/n1/mode/2up", buyLink:"https://amzn.to/4pf4mSE", blurb:"How dying populations and immigrant invasions imperil our culture and civilization. Buchanan's warning about the demographic and cultural decline of Western civilization.", reason:"Nationalism · Immigration · Cultural decline · Western civilization" },
{   id:2, title:"The Conservative Mind", author:"Russell Kirk", year:1953, cat:"philosophy", price:18.00, coverImage:"covers/conservativemind.jpg", freeLink:"https://archive.org/details/conservativemind0000kirk", buyLink:"https://amzn.to/45vdBH4", blurb:"From Burke to Eliot, Kirk traces the intellectual tradition of conservatism through two centuries of Anglo-American thought. The foundational text of modern American conservatism.", reason:"Traditionalism · Burke · Natural law · Ordered liberty" },
{   id:3, title:"The Culture of Narcissism", author:"Christopher Lasch", year:1979, cat:"sociology", price:16.00, coverImage:"covers/cultureofnarcissism.jpg", freeLink:"https://archive.org/details/cultureofnarciss0000lasc", buyLink:"https://amzn.to/4bg42iS", blurb:"American life in an age of diminishing expectations. Lasch diagnosed the self-absorbed, therapeutic culture that would define the decades to come.", reason:"Psychology · Social critique · Self-absorption · Pre-internet prophecy" },
{   id:4, title:"Bowling Alone", author:"Robert D. Putnam", year:2000, cat:"sociology", price:17.00, coverImage:"covers/bowlingalone.jpg", freeLink:"https://archive.org/details/bowlingalone00robe", buyLink:"https://amzn.to/4sohtnl", blurb:"The collapse and revival of American community. Putnam's data-driven account of how civic engagement and social trust have disintegrated since the 1960s.", reason:"Social capital · Civic decline · Community · Data-driven" },
{   id:5, title:"Reflections on the Revolution in France", author:"Edmund Burke", year:1790, cat:"philosophy", price:14.00, coverImage:"covers/reflections.jpg", freeLink:"https://archive.org/details/in.ernet.dli.2015.184486", buyLink:"https://amzn.to/3YKLobx", blurb:"The foundational conservative text. Burke's warning against radical revolution, abstract rights, and the destruction of inherited institutions and tradition.", reason:"Conservatism · Tradition · Anti-revolution · Natural order" },
{   id:6, title:"Why Liberalism Failed", author:"Patrick J. Deneen", year:2018, cat:"politics", price:20.00, coverImage:"covers/whyliberalism.jpg", freeLink:"https://archive.org/details/in.ernet.dli.2015.499590", buyLink:"https://amzn.to/4qm13Ki", blurb:"Liberalism has failed not because it fell short, but because it succeeded too well. Deneen argues that liberalism's own internal logic has produced the very problems it claimed to solve.", reason:"Post-liberalism · Tradition · Community · Anti-progress" },
{   id:7, title:"Leviathan", author:"Thomas Hobbes", year:1651, cat:"philosophy", price:15.00, coverImage:"covers/leviathan.jpg", freeLink:"https://archive.org/details/hobbessleviathan00hobbuoft", buyLink:"https://amzn.to/3YMYx3P", blurb:"The social contract and the absolute sovereign. Hobbes's bleak but influential vision of human nature and the necessity of strong authority.", reason:"Social contract · Authority · Human nature · Political philosophy" },
{   id:8, title:"Men Among the Ruins", author:"Julius Evola", year:1953, cat:"philosophy", price:19.00, coverImage:"covers/menamongruins.jpg", freeLink:"https://archive.org/details/menamongruinspos0000evol", buyLink:"https://amzn.to/4jqcApK", blurb:"Post-war reflections of a radical traditionalist. Evola's uncompromising critique of modernity and his vision of a hierarchical, spiritually-oriented social order.", reason:"Traditionalism · Hierarchy · Anti-modernity · Metaphysics" },
{   id:9, title:"Democracy: The God That Failed", author:"Hans-Hermann Hoppe", year:2001, cat:"politics", price:21.00, coverImage:"covers/democracygod.jpg", freeLink:"https://archive.org/details/democracythegodt00hans", buyLink:"https://amzn.to/3YNNwPO", blurb:"The economics and politics of monarchy, democracy, and natural order. Hoppe's libertarian argument that democracy leads to short-termism and cultural decay.", reason:"Libertarianism · Monarchy vs democracy · Time preference · Private property" },
{   id:10, title:"Suicide of the West", author:"James Burnham", year:1964, cat:"politics", price:18.00, coverImage:"covers/suicidewest.jpg", freeLink:"https://archive.org/details/in.ernet.dli.2015.49906", buyLink:"https://amzn.to/44QscNc", blurb:"An essay on the meaning and destiny of liberalism. Burnham argued that liberalism is the ideology of Western suicide — a systematic surrender of the will to survive.", reason:"Liberalism critique · Western decline · Cold War · Realism" },
{   id:11, title:"The Federalist Papers", author:"Alexander Hamilton", year:1788, cat:"history", price:16.00, coverImage:"covers/federalist.jpg", freeLink:"https://archive.org/details/in.ernet.dli.2015.213247", buyLink:"https://amzn.to/4b7lWEr", blurb:"The original defense of the U.S. Constitution. Hamilton, Madison, and Jay's essays remain the essential text for understanding the Founders' vision.", reason:"Founding · Constitution · Republic · Separation of powers" },
{   id:12, title:"Democracy in America", author:"Alexis de Tocqueville", year:1835, cat:"history", price:17.00, coverImage:"covers/democracyamerica.jpg", freeLink:"https://archive.org/details/democracyiname01tocq", buyLink:"https://amzn.to/3YcetN1", blurb:"Tocqueville's prophetic analysis of the American experiment — its strengths, its dangers, and its inevitable slide toward soft despotism.", reason:"American democracy · Equality · Despotism · Civil society" },
{   id:13, title:"The Decline of the West", author:"Oswald Spengler", year:1918, cat:"history", price:20.00, coverImage:"covers/declinewest.jpg", freeLink:"https://archive.org/details/in.ernet.dli.2015.78726", buyLink:"https://www.amazon.com/s?k=Oswald+Spengler+The+Decline+of+the+West", blurb:"Spengler's monumental cyclical theory of civilizations. The West is not a limitless progression but a living organism now entering its winter.", reason:"Civilizational cycles · Cultural morphology · Faustian soul · Winter" },
{   id:14, title:"The Israel Lobby", author:"John J. Mearsheimer", year:2007, cat:"politics", price:18.00, coverImage:"covers/israellobby.jpg", freeLink:"https://archive.org/details/israellobbyusfor0000mear", buyLink:"https://amzn.to/3YMY2qt", blurb:"How the Israel lobby shapes U.S. foreign policy. Mearsheimer and Walt's controversial academic analysis of one of the most powerful interest groups in American politics.", reason:"Foreign policy · Lobbying · Realism · Controversial" },
{   id:15, title:"The Culture of Critique", author:"Kevin B. MacDonald", year:1998, cat:"sociology", price:24.00, coverImage:"covers/cultureofcritique.jpg", buyLink:"https://www.amazon.com/s?k=Oswald+Spengler+The+Decline+of+the+West", blurb:"An evolutionary analysis of Jewish involvement in twentieth-century intellectual movements. The most controversial academic book of its era.", reason:"Evolutionary psychology · Identity politics · Controversial · Academic freedom" },
{   id:16, title:"Politics", author:"Aristotle", year:-350, cat:"philosophy", price:12.00, coverImage:"covers/politics.jpg", freeLink:"https://archive.org/details/aristotlespoliti00arisuoft", buyLink:"https://www.amazon.com/s?k=Oswald+Spengler+The+Decline+of+the+West", blurb:"The original political science. Aristotle's systematic analysis of constitutions, citizenship, virtue, and the good life — the foundation of Western political thought.", reason:"Classical philosophy · Virtue · Citizenship · Natural law" },
  { id:17, title:"1984", author:"George Orwell", year:1949, cat:"politics", price:16.00, coverImage:"covers/1984.jpg", freeLink:"https://archive.org/details/dli.ernet.240835", buyLink:"https://www.amazon.com/s?k=1984%20George%20Orwell", blurb:"In a totalitarian superstate, Winston Smith dares to think for himself. Orwell's chilling prophecy of surveillance, propaganda, and the destruction of truth.", reason:"Totalitarianism · Surveillance · Thoughtcrime · Censorship" },
  { id:18, title:"Animal Farm", author:"George Orwell", year:1945, cat:"politics", price:16.00, coverImage:"covers/animal-farm.jpg", freeLink:"https://archive.org/details/AnimalFarmByGeorgeOrwell", freeLink:"https://gutenberg.net.au/ebooks01/0100011h.html", buyLink:"https://www.amazon.com/s?k=Animal%20Farm%20George%20Orwell", blurb:"All animals are equal, but some animals are more equal than others. A savage allegory of revolution betrayed by power-hungry elites.", reason:"Allegory · Revolution · Soviet Union · Power" },
  { id:19, title:"The Communist Manifesto", author:"Karl Marx and Friedrich Engels", year:1848, cat:"politics", price:14.00, coverImage:"covers/the-communist-manifesto.jpg", freeLink:"https://archive.org/details/communistmanifesto_librivox", buyLink:"https://www.amazon.com/s?k=The%20Communist%20Manifesto%20Karl%20Marx%20and%20Friedrich%20Engels", blurb:"The most influential political pamphlet ever written. Marx and Engels' call to workers of the world to unite against capitalist exploitation.", reason:"Class warfare · Revolution · Capitalism critique · Banned in multiple regimes" },
  { id:20, title:"Das Kapital", author:"Karl Marx", year:1867, cat:"politics", price:18.00, coverImage:"covers/das-kapital.jpg", freeLink:"https://archive.org/details/in.ernet.dli.2015.124455", freeLink:"https://www.marxists.org/archive/marx/works/1867-c1/ch01.htm", buyLink:"https://www.amazon.com/s?k=Das%20Kapital%20Karl%20Marx", blurb:"The foundational critique of political economy. Marx's analysis of labor, surplus value, and the contradictions inherent in capitalism.", reason:"Economics · Labor theory · Anti-capitalism · Censorship" },
  { id:21, title:"The Road to Serfdom", author:"Friedrich Hayek", year:1944, cat:"politics", price:16.00, coverImage:"covers/the-road-to-serfdom.jpg", freeLink:"https://archive.org/details/roadtoserfdom00frie", buyLink:"https://www.amazon.com/s?k=The%20Road%20to%20Serfdom%20Friedrich%20Hayek", blurb:"Hayek's warning that centralized economic planning inevitably leads to totalitarianism. A libertarian classic that reshaped post-war political thought.", reason:"Libertarianism · Central planning · Totalitarianism · Free markets" },
  { id:22, title:"The Rights of Man", author:"Thomas Paine", year:1791, cat:"politics", price:14.00, coverImage:"covers/the-rights-of-man.jpg", freeLink:"https://archive.org/details/rightsofman00painiala", freeLink:"https://www.gutenberg.org/cache/epub/3742/pg3742-images.html", buyLink:"https://www.amazon.com/s?k=The%20Rights%20of%20Man%20Thomas%20Paine", blurb:"Paine's passionate defense of the French Revolution and universal human rights against Edmund Burke's conservatism. A rallying cry for democracy.", reason:"Human rights · French Revolution · Republicanism · Radicalism" },
  { id:23, title:"Common Sense", author:"Thomas Paine", year:1776, cat:"politics", price:14.00, coverImage:"covers/common-sense.jpg", freeLink:"https://archive.org/details/commonsense_gg_librivox", buyLink:"https://www.amazon.com/s?k=Common%20Sense%20Thomas%20Paine", blurb:"The pamphlet that convinced America to declare independence. Paine's plain-spoken argument for republican government over monarchy.", reason:"American Revolution · Independence · Republicanism · Monarchy" },
  { id:24, title:"The Social Contract", author:"Jean-Jacques Rousseau", year:1762, cat:"politics", price:14.00, coverImage:"covers/the-social-contract.jpg", freeLink:"https://archive.org/details/the_social_contract_1004_librivox", freeLink:"https://www.gutenberg.org/cache/epub/46333/pg46333-images.html", buyLink:"https://www.amazon.com/s?k=The%20Social%20Contract%20Jean-Jacques%20Rousseau", blurb:"Man is born free, yet everywhere he is in chains. Rousseau's theory of legitimate political authority based on the general will.", reason:"Popular sovereignty · General will · Freedom · Political legitimacy" },
  { id:25, title:"On Liberty", author:"John Stuart Mill", year:1859, cat:"politics", price:14.00, coverImage:"covers/on-liberty.jpg", freeLink:"https://archive.org/details/on_liberty_librivox", buyLink:"https://www.amazon.com/s?k=On%20Liberty%20John%20Stuart%20Mill", blurb:"The classic defense of individual freedom against state and social coercion. Mill's harm principle remains the bedrock of liberal thought.", reason:"Individual freedom · Harm principle · Free speech · Liberalism" },
  { id:26, title:"Leviathan", author:"Thomas Hobbes", year:1651, cat:"politics", price:14.00, coverImage:"covers/leviathan.jpg", freeLink:"https://archive.org/details/leviathan_1_2_0802_librivox", freeLink:"https://www.gutenberg.org/cache/epub/3207/pg3207-images.html", buyLink:"https://www.amazon.com/s?k=Leviathan%20Thomas%20Hobbes", blurb:"Life in the state of nature is solitary, poor, nasty, brutish, and short. Hobbes' argument for absolute sovereignty to escape the war of all against all.", reason:"Social contract · Sovereignty · Human nature · Authority" },
  { id:27, title:"The Prince", author:"Niccolo Machiavelli", year:1532, cat:"politics", price:14.00, coverImage:"covers/the-prince.jpg", freeLink:"https://archive.org/details/prince_pa_librivox", buyLink:"https://www.amazon.com/s?k=The%20Prince%20Niccolo%20Machiavelli", blurb:"The ends justify the means. Machiavelli's ruthless manual for acquiring and maintaining political power scandalized Europe for centuries.", reason:"Realpolitik · Power · Statecraft · Amorality" },
  { id:28, title:"Discourses on Livy", author:"Niccolo Machiavelli", year:1531, cat:"politics", price:14.00, coverImage:"covers/discourses-on-livy.jpg", freeLink:"https://archive.org/details/discourses_first_decade_titus_livius_1_1902_librivox", freeLink:"https://www.gutenberg.org/cache/epub/10827/pg10827-images.html", buyLink:"https://www.amazon.com/s?k=Discourses%20on%20Livy%20Niccolo%20Machiavelli", blurb:"Machiavelli's deeper reflection on republican government, civic virtue, and the maintenance of free states through citizen participation.", reason:"Republicanism · Civic virtue · Roman history · Liberty" },
  { id:29, title:"Two Treatises of Government", author:"John Locke", year:1689, cat:"politics", price:14.00, coverImage:"covers/two-treatises-of-government.jpg", freeLink:"https://archive.org/details/two_treatises_0902_librivox", buyLink:"https://www.amazon.com/s?k=Two%20Treatises%20of%20Government%20John%20Locke", blurb:"Locke's revolutionary argument for natural rights, government by consent, and the right to revolution. The philosophical foundation of modern democracy.", reason:"Natural rights · Social contract · Consent · Revolution" },
  { id:30, title:"Democracy in America", author:"Alexis de Tocqueville", year:1835, cat:"politics", price:16.00, coverImage:"covers/democracy-in-america.jpg", freeLink:"https://archive.org/details/democracy_america_vol1_0709", freeLink:"https://www.gutenberg.org/cache/epub/815/pg815-images.html", buyLink:"https://www.amazon.com/s?k=Democracy%20in%20America%20Alexis%20de%20Tocqueville", blurb:"Tocqueville's prophetic analysis of the American experiment — its strengths, its dangers, and its inevitable slide toward soft despotism.", reason:"American democracy · Equality · Despotism · Civil society" },
  { id:31, title:"Reflections on the Revolution in France", author:"Edmund Burke", year:1790, cat:"politics", price:14.00, coverImage:"covers/reflections-on-the-revolution-in-france.jpg", freeLink:"https://archive.org/details/reflections_revolution_france_mr_librivox", buyLink:"https://www.amazon.com/s?k=Reflections%20on%20the%20Revolution%20in%20France%20Edmund%20Burke", blurb:"The foundational conservative text. Burke's warning against radical revolution, abstract rights, and the destruction of inherited institutions and tradition.", reason:"Conservatism · Tradition · Anti-revolution · Natural order" },
  { id:32, title:"The Federalist Papers", author:"Alexander Hamilton, James Madison, John Jay", year:1788, cat:"politics", price:16.00, coverImage:"covers/the-federalist-papers.jpg", freeLink:"https://archive.org/details/federalist_papers_librivox", freeLink:"https://www.gutenberg.org/cache/epub/1404/pg1404-images.html", buyLink:"https://www.amazon.com/s?k=The%20Federalist%20Papers%20Alexander%20Hamilton%2C%20James%20Madison%2C%20John%20Jay", blurb:"The original defense of the U.S. Constitution. Hamilton, Madison, and Jay's essays remain the essential text for understanding the Founders' vision.", reason:"Founding · Constitution · Republic · Separation of powers" },
  { id:33, title:"The State and Revolution", author:"Vladimir Lenin", year:1917, cat:"politics", price:16.00, coverImage:"covers/the-state-and-revolution.jpg", freeLink:"https://archive.org/details/TheStateAndRevolutionVladimirLenin", buyLink:"https://www.amazon.com/s?k=The%20State%20and%20Revolution%20Vladimir%20Lenin", blurb:"Lenin's blueprint for smashing the bourgeois state and establishing the dictatorship of the proletariat. The revolutionary handbook that changed history.", reason:"Revolution · Proletariat · Dictatorship · Marxism" },
  { id:34, title:"What Is to Be Done?", author:"Vladimir Lenin", year:1902, cat:"politics", price:16.00, coverImage:"covers/what-is-to-be-done.jpg", freeLink:"https://www.marxists.org/archive/lenin/works/1901/witbd/i.htm", buyLink:"https://www.amazon.com/s?k=What%20Is%20to%20Be%20Done%3F%20Vladimir%20Lenin", blurb:"Lenin's call for a vanguard party to lead the working class to revolution. The theoretical foundation of Bolshevik organization.", reason:"Vanguard party · Class consciousness · Organization · Revolution" },
  { id:35, title:"Quotations from Chairman Mao Tse-tung", author:"Mao Zedong", year:1964, cat:"politics", price:16.00, coverImage:"covers/quotations-from-chairman-mao-tse-tung.jpg", freeLink:"https://archive.org/details/maozedongquotes", buyLink:"https://www.amazon.com/s?k=Quotations%20from%20Chairman%20Mao%20Tse-tung%20Mao%20Zedong", blurb:"The Little Red Book that became the bible of the Cultural Revolution. Mao's aphorisms on revolution, class struggle, and perpetual warfare.", reason:"Cultural Revolution · Class struggle · Propaganda · Totalitarianism" },
  { id:36, title:"The Wretched of the Earth", author:"Frantz Fanon", year:1961, cat:"politics", price:16.00, coverImage:"covers/the-wretched-of-the-earth.jpg", freeLink:"https://archive.org/details/WretchedOfTheEarthFrantzOmarFanon", freeLink:"https://www.marxists.org/subject/africa/fanon/wretched-of-the-earth.htm", buyLink:"https://www.amazon.com/s?k=The%20Wretched%20of%20the%20Earth%20Frantz%20Fanon", blurb:"The definitive text on anti-colonial struggle and the psychology of decolonization. Fanon's passionate call for violent liberation from imperial rule.", reason:"Anti-colonialism · Decolonization · Violence · Liberation" },
  { id:37, title:"Black Skin, White Masks", author:"Frantz Fanon", year:1952, cat:"philosophy", price:16.00, coverImage:"covers/black-skin-white-masks.jpg", freeLink:"https://archive.org/details/BlackSkinWhiteMasksPlutoClassics_201501", buyLink:"https://www.amazon.com/s?k=Black%20Skin%2C%20White%20Masks%20Frantz%20Fanon", blurb:"Fanon's searing analysis of the psychological damage inflicted by racism and colonial domination. A foundational text of postcolonial theory.", reason:"Racism · Colonialism · Identity · Psychology" },
  { id:38, title:"Pedagogy of the Oppressed", author:"Paulo Freire", year:1968, cat:"politics", price:16.00, coverImage:"covers/pedagogy-of-the-oppressed.jpg", freeLink:"https://archive.org/details/PedagogyOfTheOppressed-English-PauloFriere", freeLink:"https://archive.org/details/openveinsoflatin0000gale/page/n5/mode/2up", buyLink:"https://www.amazon.com/s?k=Pedagogy%20of%20the%20Oppressed%20Paulo%20Freire", blurb:"Education as a practice of freedom. Freire's revolutionary method for teaching critical consciousness to the poor and marginalized.", reason:"Education · Critical consciousness · Liberation · Marginalization" },
  { id:39, title:"The Open Veins of Latin America", author:"Eduardo Galeano", year:1971, cat:"politics", price:16.00, coverImage:"covers/the-open-veins-of-latin-america.jpg", freeLink:"https://archive.org/details/openveinsoflatin00edua", buyLink:"https://www.amazon.com/s?k=The%20Open%20Veins%20of%20Latin%20America%20Eduardo%20Galeano", blurb:"Five centuries of the plunder of a continent. Galeano's passionate indictment of colonialism, imperialism, and the extraction of Latin American wealth.", reason:"Imperialism · Colonialism · Economic exploitation · Latin America" },
  { id:40, title:"How to Read Donald Duck", author:"Ariel Dorfman and Armand Mattelart", year:1971, cat:"politics", price:16.00, coverImage:"covers/how-to-read-donald-duck.jpg", freeLink:"https://archive.org/details/howtoreaddonaldd0000dorf", freeLink:"https://archive.org/details/HowToReadDonaldDuckImperialistIdeologyInTheDisneyComic/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=How%20to%20Read%20Donald%20Duck%20Ariel%20Dorfman%20and%20Armand%20Mattelart", blurb:"Dorfman and Mattelart expose the imperialist ideology hidden in Disney comics. A classic of cultural criticism from Pinochet's Chile.", reason:"Cultural imperialism · Media criticism · Disney · Ideology" },
  { id:41, title:"The Gulag Archipelago", author:"Aleksandr Solzhenitsyn", year:1973, cat:"politics", price:18.00, coverImage:"covers/the-gulag-archipelago.jpg", freeLink:"https://archive.org/details/TheGulagArchipelago-Threevolumes", buyLink:"https://www.amazon.com/s?k=The%20Gulag%20Archipelago%20Aleksandr%20Solzhenitsyn", blurb:"Solzhenitsyn's monumental expose of the Soviet forced labor camp system. The book that helped dismantle the moral credibility of communism.", reason:"Soviet Union · Labor camps · Totalitarianism · Dissent" },
  { id:42, title:"One Day in the Life of Ivan Denisovich", author:"Aleksandr Solzhenitsyn", year:1962, cat:"politics", price:16.00, coverImage:"covers/one-day-in-the-life-of-ivan-denisovich.jpg", freeLink:"https://archive.org/details/one-day-in-the-life-of-ivan-denisovich", freeLink:"https://archive.org/details/onedayinlifeofiv0000solz/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=One%20Day%20in%20the%20Life%20of%20Ivan%20Denisovich%20Aleksandr%20Solzhenitsyn", blurb:"A single day in a Soviet labor camp, told with devastating simplicity. The first major literary work to break the silence on the Gulag.", reason:"Gulag · Soviet repression · Survival · Dissent" },
  { id:43, title:"Doctor Zhivago", author:"Boris Pasternak", year:1957, cat:"politics", price:16.00, coverImage:"covers/doctor-zhivago.jpg", freeLink:"https://archive.org/details/doctorzhivago01past", buyLink:"https://www.amazon.com/s?k=Doctor%20Zhivago%20Boris%20Pasternak", blurb:"A love story set against the Russian Revolution and Civil War. Pasternak's novel was banned in the USSR and smuggled to the West for publication.", reason:"Russian Revolution · Censorship · Romance · Dissident literature" },
  { id:44, title:"Homage to Catalonia", author:"George Orwell", year:1938, cat:"politics", price:16.00, coverImage:"covers/homage-to-catalonia.jpg", freeLink:"https://archive.org/details/HomageToCatalonia-English-GeorgeOrwell", freeLink:"https://gutenberg.net.au/ebooks02/0201111h.html", buyLink:"https://www.amazon.com/s?k=Homage%20to%20Catalonia%20George%20Orwell", blurb:"Orwell's firsthand account of fighting fascism in the Spanish Civil War. A masterpiece of war reportage and a warning about Soviet propaganda.", reason:"Spanish Civil War · Fascism · Soviet interference · Journalism" },
  { id:45, title:"The Origins of Totalitarianism", author:"Hannah Arendt", year:1951, cat:"politics", price:18.00, coverImage:"covers/the-origins-of-totalitarianism.jpg", freeLink:"https://archive.org/details/hannah-arendt-the-origins-of-totalitarianism", buyLink:"https://www.amazon.com/s?k=The%20Origins%20of%20Totalitarianism%20Hannah%20Arendt", blurb:"Arendt's magisterial analysis of how totalitarian regimes arise from the collapse of class society. Essential reading for understanding modern tyranny.", reason:"Totalitarianism · Nazism · Stalinism · Political theory" },
  { id:46, title:"Eichmann in Jerusalem", author:"Hannah Arendt", year:1963, cat:"philosophy", price:16.00, coverImage:"covers/eichmann-in-jerusalem.jpg", freeLink:"https://archive.org/details/arendt-hannah-eichmann-in-jerusalem", freeLink:"https://archive.org/details/eichmanninjerusa00aren/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Eichmann%20in%20Jerusalem%20Hannah%20Arendt", blurb:"Arendt's controversial report on the banality of evil. Her analysis of Adolf Eichmann's trial challenged how we understand responsibility for atrocity.", reason:"Holocaust · Evil · Responsibility · Controversy" },
  { id:47, title:"The Human Condition", author:"Hannah Arendt", year:1958, cat:"politics", price:16.00, coverImage:"covers/the-human-condition.jpg", freeLink:"https://archive.org/details/humancondition0000aren", buyLink:"https://www.amazon.com/s?k=The%20Human%20Condition%20Hannah%20Arendt", blurb:"Arendt's philosophical exploration of labor, work, and action in the vita activa. A profound meditation on what it means to live a genuinely political life.", reason:"Political philosophy · Action · Labor · Modernity" },
  { id:48, title:"Discipline and Punish", author:"Michel Foucault", year:1975, cat:"philosophy", price:16.00, coverImage:"covers/discipline-and-punish.jpg", freeLink:"https://archive.org/details/disciplinepunish0000fouc_j5k6", freeLink:"https://archive.org/details/disciplinepunish0000fouc/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Discipline%20and%20Punish%20Michel%20Foucault", blurb:"Foucault traces the transformation from public execution to the modern prison, revealing how power operates through surveillance and normalization.", reason:"Surveillance · Prison · Power · Social control" },
  { id:49, title:"The History of Sexuality", author:"Michel Foucault", year:1976, cat:"philosophy", price:16.00, coverImage:"covers/the-history-of-sexuality.jpg", freeLink:"https://archive.org/details/foucault-the-history-of-sexuality-volume-1", buyLink:"https://www.amazon.com/s?k=The%20History%20of%20Sexuality%20Michel%20Foucault", blurb:"Sexuality is not a natural given but a construct of power. Foucault's radical rethinking of how societies regulate bodies and desires.", reason:"Sexuality · Power · Social construction · Repression" },
  { id:50, title:"Madness and Civilization", author:"Michel Foucault", year:1961, cat:"philosophy", price:16.00, coverImage:"covers/madness-and-civilization.jpg", freeLink:"https://archive.org/details/madnesscivilizat0000mich", freeLink:"https://archive.org/details/madnesscivilizat00fouc/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Madness%20and%20Civilization%20Michel%20Foucault", blurb:"Foucault's history of how Western society confined and medicalized madness, transforming the madman from a vessel of truth into a pathological case.", reason:"Madness · Psychiatry · Power · Social exclusion" },
  { id:51, title:"The Second Sex", author:"Simone de Beauvoir", year:1949, cat:"philosophy", price:16.00, coverImage:"covers/the-second-sex.jpg", freeLink:"https://archive.org/details/1949SimoneDeBeauvoirTheSecondSex", buyLink:"https://www.amazon.com/s?k=The%20Second%20Sex%20Simone%20de%20Beauvoir", blurb:"One is not born, but rather becomes, a woman. Beauvoir's existentialist analysis of women's oppression remains the cornerstone of feminist philosophy.", reason:"Feminism · Existentialism · Gender · Oppression" },
  { id:52, title:"The Ethics of Ambiguity", author:"Simone de Beauvoir", year:1947, cat:"philosophy", price:16.00, coverImage:"covers/the-ethics-of-ambiguity.jpg", freeLink:"https://archive.org/details/ethicsofambiguit00beau", freeLink:"https://www.marxists.org/reference/subject/ethics/de-beauvoir/ambiguity/ch01.htm", buyLink:"https://www.amazon.com/s?k=The%20Ethics%20of%20Ambiguity%20Simone%20de%20Beauvoir", blurb:"Beauvoir applies existentialism to ethics, arguing that freedom demands action and that we are responsible for creating meaning in an ambiguous world.", reason:"Existentialism · Ethics · Freedom · Responsibility" },
  { id:53, title:"Being and Nothingness", author:"Jean-Paul Sartre", year:1943, cat:"philosophy", price:18.00, coverImage:"covers/being-and-nothingness.jpg", freeLink:"https://archive.org/details/beingnothingness0000jean", buyLink:"https://www.amazon.com/s?k=Being%20and%20Nothingness%20Jean-Paul%20Sartre", blurb:"Sartre's monumental treatise on existential phenomenology. We are condemned to be free, and existence precedes essence.", reason:"Existentialism · Freedom · Consciousness · Phenomenology" },
  { id:54, title:"Nausea", author:"Jean-Paul Sartre", year:1938, cat:"philosophy", price:16.00, coverImage:"covers/nausea.jpg", freeLink:"https://archive.org/details/nausea00sart_0", freeLink:"https://archive.org/details/nausea0000sart/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Nausea%20Jean-Paul%20Sartre", blurb:"Roquentin's existential crisis in a provincial town reveals the contingency and absurdity of existence. Sartre's first novel and existentialist manifesto.", reason:"Existentialism · Absurdity · Contingency · Alienation" },
  { id:55, title:"The Myth of Sisyphus", author:"Albert Camus", year:1942, cat:"philosophy", price:16.00, coverImage:"covers/the-myth-of-sisyphus.jpg", freeLink:"https://archive.org/details/AlbertCamusTheMythOfSisyphus", buyLink:"https://www.amazon.com/s?k=The%20Myth%20of%20Sisyphus%20Albert%20Camus", blurb:"There is but one truly serious philosophical problem, and that is suicide. Camus' essay on absurdity and the revolt that gives life meaning.", reason:"Absurdism · Suicide · Meaning · Revolt" },
  { id:56, title:"The Rebel", author:"Albert Camus", year:1951, cat:"politics", price:16.00, coverImage:"covers/the-rebel.jpg", freeLink:"https://archive.org/details/rebelessayonmani00camu", freeLink:"https://archive.org/details/rebelessayonmani00camu/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=The%20Rebel%20Albert%20Camus", blurb:"Camus examines revolution and rebellion from the French Revolution to the Soviet era, arguing that murder in the name of utopia destroys humanity.", reason:"Rebellion · Revolution · Violence · Humanism" },
  { id:57, title:"Thus Spoke Zarathustra", author:"Friedrich Nietzsche", year:1883, cat:"philosophy", price:14.00, coverImage:"covers/thus-spoke-zarathustra.jpg", freeLink:"https://archive.org/details/thusspokezarathu00nietuoft", buyLink:"https://www.amazon.com/s?k=Thus%20Spoke%20Zarathustra%20Friedrich%20Nietzsche", blurb:"Nietzsche's philosophical novel announces the death of God and the coming of the Ubermensch. A prophetic, poetic masterpiece of modern thought.", reason:"Nihilism · Ubermensch · Will to power · Prophecy" },
  { id:58, title:"Beyond Good and Evil", author:"Friedrich Nietzsche", year:1886, cat:"philosophy", price:14.00, coverImage:"covers/beyond-good-and-evil.jpg", freeLink:"https://archive.org/details/beyond_good_and_evil_librivox", freeLink:"https://www.gutenberg.org/cache/epub/4363/pg4363-images.html", buyLink:"https://www.amazon.com/s?k=Beyond%20Good%20and%20Evil%20Friedrich%20Nietzsche", blurb:"Nietzsche demolishes traditional morality and calls for a revaluation of all values. A devastating critique of religion, philosophy, and democracy.", reason:"Morality · Religion · Democracy critique · Revaluation" },
  { id:59, title:"The Genealogy of Morals", author:"Friedrich Nietzsche", year:1887, cat:"philosophy", price:14.00, coverImage:"covers/the-genealogy-of-morals.jpg", freeLink:"https://archive.org/details/beyondgoodandevil_1910_librivox", buyLink:"https://www.amazon.com/s?k=The%20Genealogy%20of%20Morals%20Friedrich%20Nietzsche", blurb:"Nietzsche traces the origins of guilt, conscience, and ascetic ideals to resentment and the will to power. A psychological masterwork.", reason:"Morality · Resentment · Guilt · Psychology" },
  { id:60, title:"The Will to Power", author:"Friedrich Nietzsche", year:1901, cat:"philosophy", price:14.00, coverImage:"covers/the-will-to-power.jpg", freeLink:"https://archive.org/details/the_twilight_of_the_idols_librivox", freeLink:"https://archive.org/details/TheWillToPower-Nietzsche/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=The%20Will%20to%20Power%20Friedrich%20Nietzsche", blurb:"A posthumous collection of Nietzsche's notes on nihilism, power, and the transvaluation of values. Controversial but indispensable for understanding his thought.", reason:"Nihilism · Power · Transvaluation · Posthumous" },
  { id:61, title:"Critique of Pure Reason", author:"Immanuel Kant", year:1781, cat:"philosophy", price:14.00, coverImage:"covers/critique-of-pure-reason.jpg", freeLink:"https://archive.org/details/critique_pure_reason_0709_librivox", buyLink:"https://www.amazon.com/s?k=Critique%20of%20Pure%20Reason%20Immanuel%20Kant", blurb:"Kant's revolutionary investigation into the limits of human knowledge. We can only know phenomena, not things-in-themselves.", reason:"Epistemology · Reason · Phenomena · Limits of knowledge" },
  { id:62, title:"Religion within the Bounds of Bare Reason", author:"Immanuel Kant", year:1793, cat:"philosophy", price:14.00, coverImage:"covers/religion-within-the-bounds-of-bare-reason.jpg", freeLink:"https://archive.org/details/kantsreligionwit0000kant/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Religion%20within%20the%20Bounds%20of%20Bare%20Reason%20Immanuel%20Kant", blurb:"Kant argues that moral religion requires no revelation, only reason. A radical rethinking of faith that scandalized theologians and censors alike.", reason:"Religion · Morality · Reason · Enlightenment" },
  { id:63, title:"The Republic", author:"Plato", year:-375, cat:"politics", price:14.00, coverImage:"covers/the-republic.jpg", freeLink:"https://archive.org/details/republic_version_2_1310_librivox", buyLink:"https://www.amazon.com/s?k=The%20Republic%20Plato", blurb:"Plato's vision of the just city ruled by philosopher-kings. The foundational text of Western political philosophy and the theory of ideal forms.", reason:"Justice · Philosopher-king · Ideal forms · Utopia" },
  { id:64, title:"Politics", author:"Aristotle", year:-350, cat:"politics", price:14.00, coverImage:"covers/politics.jpg", freeLink:"https://archive.org/details/politics_0802_librivox", freeLink:"https://www.gutenberg.org/cache/epub/6762/pg6762-images.html", buyLink:"https://www.amazon.com/s?k=Politics%20Aristotle", blurb:"The original political science. Aristotle's systematic analysis of constitutions, citizenship, virtue, and the good life — the foundation of Western political thought.", reason:"Classical philosophy · Virtue · Citizenship · Natural law" },
  { id:65, title:"The Art of War", author:"Sun Tzu", year:-500, cat:"politics", price:14.00, coverImage:"covers/the-art-of-war.jpg", freeLink:"https://archive.org/details/art_of_war_librivox", buyLink:"https://www.amazon.com/s?k=The%20Art%20of%20War%20Sun%20Tzu", blurb:"The ancient Chinese treatise on strategy, deception, and victory without battle. Still studied in military academies and boardrooms worldwide.", reason:"Strategy · Warfare · Deception · Leadership" },
  { id:66, title:"The Trial", author:"Franz Kafka", year:1925, cat:"politics", price:16.00, coverImage:"covers/the-trial.jpg", freeLink:"https://archive.org/details/metamorphosis_librivox", freeLink:"https://www.gutenberg.org/cache/epub/7849/pg7849-images.html", buyLink:"https://www.amazon.com/s?k=The%20Trial%20Franz%20Kafka", blurb:"Joseph K. is arrested and executed without ever learning his crime. Kafka's nightmare vision of modern bureaucracy and incomprehensible justice.", reason:"Bureaucracy · Absurdism · Guilt · Totalitarianism" },
  { id:67, title:"Brave New World", author:"Aldous Huxley", year:1932, cat:"politics", price:16.00, coverImage:"covers/brave-new-world.jpg", freeLink:"https://archive.org/details/ost-english-brave_new_world_aldous_huxley", buyLink:"https://www.amazon.com/s?k=Brave%20New%20World%20Aldous%20Huxley", blurb:"A future of genetic engineering, soma, and manufactured happiness. Huxley's dystopia warns that pleasure, not pain, may be the ultimate instrument of control.", reason:"Dystopia · Genetic engineering · Hedonism · Control" },
  { id:68, title:"Fahrenheit 451", author:"Ray Bradbury", year:1953, cat:"politics", price:16.00, coverImage:"covers/fahrenheit-451.jpg", freeLink:"https://archive.org/details/fahrenheit4510000brad", freeLink:"https://archive.org/details/RayBradburyFahrenheit451Novel1953/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Fahrenheit%20451%20Ray%20Bradbury", blurb:"Firemen burn books in a society where critical thought is criminal. Bradbury's warning about censorship, entertainment, and the death of curiosity.", reason:"Censorship · Book burning · Anti-intellectualism · Conformity" },
  { id:69, title:"A Clockwork Orange", author:"Anthony Burgess", year:1962, cat:"politics", price:16.00, coverImage:"covers/a-clockwork-orange.jpg", freeLink:"https://archive.org/details/AClockworkOrange_Unabridged", buyLink:"https://www.amazon.com/s?k=A%20Clockwork%20Orange%20Anthony%20Burgess", blurb:"Ultraviolence and state-sponsored mind control collide in Burgess' disturbing fable of free will. Can goodness be mechanically imposed?", reason:"Free will · Violence · Behaviorism · Morality" },
  { id:70, title:"We", author:"Yevgeny Zamyatin", year:1924, cat:"politics", price:16.00, coverImage:"covers/we.jpg", freeLink:"https://archive.org/details/we_2304_librivox", freeLink:"https://archive.org/details/we00zami/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=We%20Yevgeny%20Zamyatin", blurb:"The original dystopian novel that inspired 1984 and Brave New World. Zamyatin's We envisioned total surveillance and the destruction of the individual.", reason:"Dystopia · Surveillance · Individuality · Totalitarianism" },
  { id:71, title:"Darkness at Noon", author:"Arthur Koestler", year:1940, cat:"politics", price:16.00, coverImage:"covers/darkness-at-noon.jpg", freeLink:"https://archive.org/details/in.ernet.dli.2015.99646", buyLink:"https://www.amazon.com/s?k=Darkness%20at%20Noon%20Arthur%20Koestler", blurb:"A former Bolshevik is forced to confess to imaginary crimes in Stalin's show trials. Koestler's devastating portrait of ideological self-destruction.", reason:"Stalinism · Show trials · Confession · Ideology" },
  { id:72, title:"The Handmaid's Tale", author:"Margaret Atwood", year:1985, cat:"politics", price:16.00, coverImage:"covers/the-handmaid-s-tale.jpg", freeLink:"https://archive.org/details/the-handmaid-s-tale-graphic-novel-by-margaret-atwood", freeLink:"https://archive.org/details/handmaidstale0000atwo_h6r1/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=The%20Handmaid's%20Tale%20Margaret%20Atwood", blurb:"A theocratic regime reduces women to breeders in a dystopian America. Atwood's chilling warning about religious fundamentalism and patriarchal control.", reason:"Theocracy · Patriarchy · Reproductive rights · Dystopia" },
  { id:73, title:"The Grapes of Wrath", author:"John Steinbeck", year:1939, cat:"history", price:16.00, coverImage:"covers/the-grapes-of-wrath.jpg", freeLink:"https://archive.org/details/the-grapes-of-wrath-1940", buyLink:"https://www.amazon.com/s?k=The%20Grapes%20of%20Wrath%20John%20Steinbeck", blurb:"Dust Bowl farmers are driven from their land and crushed by economic forces beyond their control. Steinbeck's epic of dignity amid American poverty.", reason:"Great Depression · Poverty · Migration · Labor" },
  { id:74, title:"Of Mice and Men", author:"John Steinbeck", year:1937, cat:"sociology", price:16.00, coverImage:"covers/of-mice-and-men.jpg", freeLink:"https://archive.org/details/in.ernet.dli.2015.507266", freeLink:"https://archive.org/details/ofmicemen00stei_3/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Of%20Mice%20and%20Men%20John%20Steinbeck", blurb:"Two migrant workers dream of owning land in a world that crushes the weak. Steinbeck's tragedy of friendship, loneliness, and the American Dream.", reason:"Poverty · Friendship · American Dream · Disability" },
  { id:75, title:"To Kill a Mockingbird", author:"Harper Lee", year:1960, cat:"history", price:16.00, coverImage:"covers/to-kill-a-mockingbird.jpg", freeLink:"https://archive.org/details/tokillmockingbir0000leeh", buyLink:"https://www.amazon.com/s?k=To%20Kill%20a%20Mockingbird%20Harper%20Lee", blurb:"Atticus Finch defends a Black man falsely accused of rape in the Jim Crow South. A timeless examination of racism, courage, and moral conscience.", reason:"Racism · Jim Crow · Justice · Courage" },
  { id:76, title:"The Adventures of Huckleberry Finn", author:"Mark Twain", year:1884, cat:"history", price:14.00, coverImage:"covers/the-adventures-of-huckleberry-finn.jpg", freeLink:"https://archive.org/details/tom_sawyer_librivox", freeLink:"https://www.gutenberg.org/cache/epub/76/pg76-images.html", buyLink:"https://www.amazon.com/s?k=The%20Adventures%20of%20Huckleberry%20Finn%20Mark%20Twain", blurb:"Huck and Jim's river journey exposes the cruelty and absurdity of antebellum America. The most banned American classic for its language and truth.", reason:"Slavery · Racism · Adventure · Controversy" },
  { id:77, title:"Native Son", author:"Richard Wright", year:1940, cat:"politics", price:16.00, coverImage:"covers/native-son.jpg", freeLink:"https://archive.org/details/in.ernet.dli.2015.499539", buyLink:"https://www.amazon.com/s?k=Native%20Son%20Richard%20Wright", blurb:"Bigger Thomas' violence forces America to confront systemic racism. Wright's unflinching naturalist novel shattered the liberal consensus on race.", reason:"Racism · Violence · Systemic oppression · Naturalism" },
  { id:78, title:"Black Boy", author:"Richard Wright", year:1945, cat:"history", price:16.00, coverImage:"covers/black-boy.jpg", freeLink:"https://archive.org/details/in.ernet.dli.2015.5717", freeLink:"https://archive.org/details/blackboy00rich/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Black%20Boy%20Richard%20Wright", blurb:"Wright's autobiography of growing up Black in the Jim Crow South. A searing account of hunger, violence, and the struggle for intellectual freedom.", reason:"Autobiography · Jim Crow · Hunger · Intellectual freedom" },
  { id:79, title:"Invisible Man", author:"Ralph Ellison", year:1952, cat:"politics", price:16.00, coverImage:"covers/invisible-man.jpg", freeLink:"https://archive.org/details/battle-royal", buyLink:"https://www.amazon.com/s?k=Invisible%20Man%20Ralph%20Ellison", blurb:"A nameless Black man navigates a society that refuses to see him. Ellison's masterpiece of identity, visibility, and the American racial nightmare.", reason:"Identity · Racism · Invisibility · American Dream" },
  { id:80, title:"Go Tell It on the Mountain", author:"James Baldwin", year:1953, cat:"sociology", price:16.00, coverImage:"covers/go-tell-it-on-the-mountain.jpg", freeLink:"https://archive.org/details/GoTellItToTheMountain1984", freeLink:"https://archive.org/details/gotellitonmounta0000bald/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Go%20Tell%20It%20on%20the%20Mountain%20James%20Baldwin", blurb:"A Harlem teenager confronts religion, family, and sexuality on his fourteenth birthday. Baldwin's semi-autobiographical debut of spiritual crisis.", reason:"Religion · Sexuality · Harlem · Coming of age" },
  { id:81, title:"The Fire Next Time", author:"James Baldwin", year:1963, cat:"politics", price:16.00, coverImage:"covers/the-fire-next-time.jpg", freeLink:"https://archive.org/details/firenexttime00bald_0", buyLink:"https://www.amazon.com/s?k=The%20Fire%20Next%20Time%20James%20Baldwin", blurb:"Baldwin's urgent letters on race in America. If we do not dare everything, the fulfillment of that prophecy, re-created from the Bible in song by a slave, is upon us.", reason:"Race · Religion · Civil rights · Prophecy" },
  { id:82, title:"I Know Why the Caged Bird Sings", author:"Maya Angelou", year:1969, cat:"history", price:16.00, coverImage:"covers/i-know-why-the-caged-bird-sings.jpg", freeLink:"https://archive.org/details/iknowwhycagedbir0000unse_x1z8", freeLink:"https://archive.org/details/iknowwhycagedbir00ange/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=I%20Know%20Why%20the%20Caged%20Bird%20Sings%20Maya%20Angelou", blurb:"Angelou's autobiography of trauma, racism, and finding her voice in the segregated South. A testament to the resilience of the human spirit.", reason:"Autobiography · Trauma · Racism · Resilience" },
  { id:83, title:"The Autobiography of Malcolm X", author:"Malcolm X and Alex Haley", year:1965, cat:"politics", price:16.00, coverImage:"covers/the-autobiography-of-malcolm-x.jpg", freeLink:"https://archive.org/details/autobiographyofm00malc", buyLink:"https://www.amazon.com/s?k=The%20Autobiography%20of%20Malcolm%20X%20Malcolm%20X%20and%20Alex%20Haley", blurb:"From street hustler to revolutionary icon, Malcolm X tells his story with unflinching honesty. One of the most influential American autobiographies ever written.", reason:"Autobiography · Black nationalism · Islam · Transformation" },
  { id:84, title:"Soul on Ice", author:"Eldridge Cleaver", year:1968, cat:"politics", price:16.00, coverImage:"covers/soul-on-ice.jpg", freeLink:"https://archive.org/details/soulonicebyeldridgecleaver", freeLink:"https://archive.org/details/soulonice00clea/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Soul%20on%20Ice%20Eldridge%20Cleaver", blurb:"Cleaver's essays from Folsom Prison electrified the Black Power movement. Controversial, provocative, and essential to understanding 1960s radicalism.", reason:"Black Power · Prison · Revolution · Controversy" },
  { id:85, title:"Assata: An Autobiography", author:"Assata Shakur", year:1987, cat:"politics", price:16.00, coverImage:"covers/assata-an-autobiography.jpg", freeLink:"https://archive.org/details/Assata", buyLink:"https://www.amazon.com/s?k=Assata%3A%20An%20Autobiography%20Assata%20Shakur", blurb:"Shakur's account of her life, trial, and escape from prison. A powerful document of Black liberation and state repression in America.", reason:"Black Liberation · Prison · Police · State repression" },
  { id:86, title:"The New Jim Crow", author:"Michelle Alexander", year:2010, cat:"politics", price:16.00, coverImage:"covers/the-new-jim-crow.jpg", freeLink:"https://archive.org/details/newjimcrowmassin0000alex", freeLink:"https://archive.org/details/newjimcrowmassin0000alex/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=The%20New%20Jim%20Crow%20Michelle%20Alexander", blurb:"Mass incarceration has replaced segregation as the primary tool of racial control. Alexander's devastating legal and historical analysis.", reason:"Mass incarceration · Racism · Criminal justice · Systemic oppression" },
  { id:87, title:"Stamped from the Beginning", author:"Ibram X. Kendi", year:2016, cat:"history", price:16.00, coverImage:"covers/stamped-from-the-beginning.jpg", freeLink:"https://archive.org/details/stampedfrombegin0000kend", buyLink:"https://www.amazon.com/s?k=Stamped%20from%20the%20Beginning%20Ibram%20X.%20Kendi", blurb:"Kendi traces the history of racist ideas from Puritan America to the present. A comprehensive account of how anti-Black thought was constructed and defended.", reason:"Racism · Intellectual history · Anti-Blackness · Construction" },
  { id:88, title:"How to Be an Antiracist", author:"Ibram X. Kendi", year:2019, cat:"politics", price:16.00, coverImage:"covers/how-to-be-an-antiracist.jpg", freeLink:"https://archive.org/details/howtobeantiracis0000kend_v1i0", freeLink:"https://archive.org/details/how-to-be-an-antiracist-by-ibram-x.-kendi/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=How%20to%20Be%20an%20Antiracist%20Ibram%20X.%20Kendi", blurb:"Kendi argues that neutrality is impossible in a racist society. A memoir and manifesto for actively dismantling racist policies and ideas.", reason:"Antiracism · Policy · Neutrality · Activism" },
  { id:89, title:"White Fragility", author:"Robin DiAngelo", year:2018, cat:"sociology", price:16.00, coverImage:"covers/white-fragility.jpg", freeLink:"https://archive.org/details/lacanian-rewrites-white-fragility", buyLink:"https://www.amazon.com/s?k=White%20Fragility%20Robin%20DiAngelo", blurb:"DiAngelo examines why white Americans struggle to talk about racism. A provocative analysis of defensive reactions to racial inequality.", reason:"Whiteness · Defensiveness · Racial inequality · Privilege" },
  { id:90, title:"Between the World and Me", author:"Ta-Nehisi Coates", year:2015, cat:"politics", price:16.00, coverImage:"covers/between-the-world-and-me.jpg", freeLink:"https://archive.org/details/betweenworldme0000coat_d7q6", freeLink:"https://archive.org/details/betweenworldme0000coat/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Between%20the%20World%20and%20Me%20Ta-Nehisi%20Coates", blurb:"Coates' letter to his son about being Black in America. A searing meditation on the body, fear, and the American dream's betrayal.", reason:"Black body · Fear · Fatherhood · American Dream" },
  { id:91, title:"A People's History of the United States", author:"Howard Zinn", year:1980, cat:"politics", price:16.00, coverImage:"covers/a-people-s-history-of-the-united-states.jpg", freeLink:"https://archive.org/details/pdfy-otanUZGGGcnDgfr7", buyLink:"https://www.amazon.com/s?k=A%20People's%20History%20of%20the%20United%20States%20Howard%20Zinn", blurb:"History from the perspective of workers, women, slaves, and indigenous people. Zinn's revisionist classic challenges every heroic national myth.", reason:"Revisionism · Class struggle · Indigenous · Labor" },
  { id:92, title:"Lies My Teacher Told Me", author:"James W. Loewen", year:1995, cat:"history", price:16.00, coverImage:"covers/lies-my-teacher-told-me.jpg", freeLink:"https://archive.org/details/liesmyteachertol0000loew", freeLink:"https://archive.org/details/liesmyteachertol00loew_0/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Lies%20My%20Teacher%20Told%20Me%20James%20W.%20Loewen", blurb:"Loewen reveals the omissions, distortions, and false hero worship in American history textbooks. Essential reading for historical literacy.", reason:"Textbooks · Historical distortion · Mythology · Education" },
  { id:93, title:"Bury My Heart at Wounded Knee", author:"Dee Brown", year:1970, cat:"politics", price:16.00, coverImage:"covers/bury-my-heart-at-wounded-knee.jpg", freeLink:"https://archive.org/details/burymyheartatwou00brow", buyLink:"https://www.amazon.com/s?k=Bury%20My%20Heart%20at%20Wounded%20Knee%20Dee%20Brown", blurb:"The systematic destruction of Native American tribes from 1860 to 1890, told from indigenous perspectives. A heartbreaking chronicle of genocide.", reason:"Native American · Genocide · Westward expansion · Broken treaties" },
  { id:94, title:"An Indigenous Peoples' History of the United States", author:"Roxanne Dunbar-Ortiz", year:2014, cat:"politics", price:16.00, coverImage:"covers/an-indigenous-peoples-history-of-the-united-states.jpg", freeLink:"https://archive.org/details/indigenouspeople0000dunb/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=An%20Indigenous%20Peoples'%20History%20of%20the%20United%20States%20Roxanne%20Dunbar-Ortiz", blurb:"Dunbar-Ortiz reframes American history as a centuries-long project of indigenous dispossession. A necessary corrective to settler colonial narratives.", reason:"Indigenous · Settler colonialism · Dispossession · Resistance" },
  { id:95, title:"1491", author:"Charles C. Mann", year:2005, cat:"history", price:16.00, coverImage:"covers/1491.jpg", freeLink:"https://archive.org/details/149100char", buyLink:"https://www.amazon.com/s?k=1491%20Charles%20C.%20Mann", blurb:"The Americas before Columbus were far more populous and sophisticated than we were taught. Mann demolishes the myth of pristine wilderness.", reason:"Pre-Columbian · Indigenous · Demographics · Revisionism" },
  { id:96, title:"1493", author:"Charles C. Mann", year:2011, cat:"history", price:16.00, coverImage:"covers/1493.jpg", freeLink:"https://archive.org/details/1493uncoveringne00mann", freeLink:"https://archive.org/details/1493uncoveringne0000mann/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=1493%20Charles%20C.%20Mann", blurb:"The Columbian Exchange created a new world of trade, disease, and ecological transformation. Mann traces the global consequences of 1492.", reason:"Columbian Exchange · Globalization · Ecology · Trade" },
  { id:97, title:"The Diary of a Young Girl", author:"Anne Frank", year:1947, cat:"history", price:16.00, coverImage:"covers/the-diary-of-a-young-girl.jpg", freeLink:"https://archive.org/details/diaryofyounggir000fran", buyLink:"https://www.amazon.com/s?k=The%20Diary%20of%20a%20Young%20Girl%20Anne%20Frank", blurb:"A Jewish girl hides from the Nazis in an Amsterdam attic, recording her hopes, fears, and growing up in confinement. Humanity's most read Holocaust document.", reason:"Holocaust · Jewish · Diary · Innocence" },
  { id:98, title:"Night", author:"Elie Wiesel", year:1960, cat:"history", price:16.00, coverImage:"covers/night.jpg", freeLink:"https://archive.org/details/elie-wiesel-night-full-text", freeLink:"https://archive.org/details/NightElieWiesel/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Night%20Elie%20Wiesel", blurb:"Wiesel's memoir of surviving Auschwitz and Buchenwald. A devastating testimony to the death of God, the death of innocence, and the death of humanity.", reason:"Holocaust · Auschwitz · Faith · Testimony" },
  { id:99, title:"Maus", author:"Art Spiegelman", year:1980, cat:"history", price:16.00, coverImage:"covers/maus.jpg", freeLink:"https://archive.org/details/maus-part-ii", buyLink:"https://www.amazon.com/s?k=Maus%20Art%20Spiegelman", blurb:"Nazis are cats, Jews are mice in this Pulitzer-winning graphic novel. Spiegelman's father's survival story becomes a meditation on trauma and memory.", reason:"Holocaust · Graphic novel · Trauma · Memory" },
  { id:100, title:"Persepolis", author:"Marjane Satrapi", year:2000, cat:"politics", price:16.00, coverImage:"covers/persepolis.jpg", freeLink:"https://archive.org/details/persepolis_202107", freeLink:"https://archive.org/details/persepolisstoryo0000satr/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Persepolis%20Marjane%20Satrapi", blurb:"A young girl comes of age during the Iranian Revolution and Iran-Iraq War. Satrapi's graphic memoir captures the absurdity and tragedy of living under fundamentalism.", reason:"Iranian Revolution · Graphic memoir · Fundamentalism · Childhood" },
  { id:101, title:"The Things They Carried", author:"Tim O'Brien", year:1990, cat:"politics", price:16.00, coverImage:"covers/the-things-they-carried.jpg", freeLink:"https://archive.org/details/the-things-they-carried-tim-o-brien", buyLink:"https://www.amazon.com/s?k=The%20Things%20They%20Carried%20Tim%20O'Brien", blurb:"A metafictional masterpiece about the Vietnam War and the stories soldiers tell to survive. Blurring truth and fiction, O'Brien captures war's moral ambiguity.", reason:"Vietnam War · Fiction · Truth · Memory" },
  { id:102, title:"Catch-22", author:"Joseph Heller", year:1961, cat:"politics", price:16.00, coverImage:"covers/catch-22.jpg", freeLink:"https://archive.org/details/catch22novel0000hell", freeLink:"https://archive.org/details/catch220000hell/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Catch-22%20Joseph%20Heller", blurb:"A bombardier tries to prove he is insane to avoid flying more missions, but only a sane man would want to stop. Heller's absurdist war satire.", reason:"War · Bureaucracy · Absurdism · Satire" },
  { id:103, title:"Slaughterhouse-Five", author:"Kurt Vonnegut", year:1969, cat:"politics", price:16.00, coverImage:"covers/slaughterhouse-five.jpg", freeLink:"https://archive.org/details/slaughterhousefi00vonn_0", buyLink:"https://www.amazon.com/s?k=Slaughterhouse-Five%20Kurt%20Vonnegut", blurb:"Billy Pilgrim becomes unstuck in time after surviving the firebombing of Dresden. Vonnegut's anti-war classic fuses sci-fi with the trauma of total war.", reason:"Dresden · Time travel · Anti-war · Trauma" },
  { id:104, title:"Johnny Got His Gun", author:"Dalton Trumbo", year:1939, cat:"politics", price:16.00, coverImage:"covers/johnny-got-his-gun.jpg", freeLink:"https://archive.org/details/johnny-got-his-gun", freeLink:"https://archive.org/details/johnnygothisgun00trum/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Johnny%20Got%20His%20Gun%20Dalton%20Trumbo", blurb:"A soldier loses his limbs, face, and senses but remains conscious. Trumbo's nightmarish anti-war novel was blacklisted during the McCarthy era.", reason:"Anti-war · Disability · Consciousness · Blacklist" },
  { id:105, title:"All Quiet on the Western Front", author:"Erich Maria Remarque", year:1929, cat:"politics", price:16.00, coverImage:"covers/all-quiet-on-the-western-front.jpg", freeLink:"https://archive.org/details/allquietonthewesternfront_2505_librivox", buyLink:"https://www.amazon.com/s?k=All%20Quiet%20on%20the%20Western%20Front%20Erich%20Maria%20Remarque", blurb:"A German soldier loses his innocence and his generation in the trenches of World War I. Remarque's unflinching classic was banned and burned by the Nazis.", reason:"World War I · Trench warfare · Loss of innocence · Nazi book burning" },
  { id:106, title:"The Jungle", author:"Upton Sinclair", year:1906, cat:"politics", price:16.00, coverImage:"covers/the-jungle.jpg", freeLink:"https://archive.org/details/jungle_tw_0908_librivox", freeLink:"https://www.gutenberg.org/cache/epub/140/pg140-images.html", buyLink:"https://www.amazon.com/s?k=The%20Jungle%20Upton%20Sinclair", blurb:"Lithuanian immigrants are ground up by Chicago's meatpacking industry. Sinclair aimed for America's heart and hit its stomach, sparking food safety reform.", reason:"Labor · Immigration · Meatpacking · Muckraking" },
  { id:107, title:"Nickel and Dimed", author:"Barbara Ehrenreich", year:2001, cat:"politics", price:16.00, coverImage:"covers/nickel-and-dimed.jpg", freeLink:"https://archive.org/details/nickeldimedonnot00barb_0", buyLink:"https://www.amazon.com/s?k=Nickel%20and%20Dimed%20Barbara%20Ehrenreich", blurb:"A journalist goes undercover in minimum-wage America and discovers that hard work does not pay the rent. A damning indictment of the working poor.", reason:"Poverty · Minimum wage · Working poor · Inequality" },
  { id:108, title:"Evicted", author:"Matthew Desmond", year:2016, cat:"sociology", price:16.00, coverImage:"covers/evicted.jpg", freeLink:"https://archive.org/details/evictedpovertypr0000desm_m1n2", freeLink:"https://archive.org/details/evictedpovertypr0000desm/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Evicted%20Matthew%20Desmond", blurb:"Desmond follows eight families in Milwaukee as they struggle to keep a roof over their heads. A landmark work on housing, poverty, and exploitation.", reason:"Housing · Eviction · Poverty · Inequality" },
  { id:109, title:"The Color Purple", author:"Alice Walker", year:1982, cat:"history", price:16.00, coverImage:"covers/the-color-purple.jpg", freeLink:"https://archive.org/details/colorpurple00walk_0", buyLink:"https://www.amazon.com/s?k=The%20Color%20Purple%20Alice%20Walker", blurb:"Celie finds her voice and her freedom through sisterhood and self-love in the Jim Crow South. Walker's Pulitzer-winning epistolary novel.", reason:"Racism · Sexism · Sisterhood · Self-discovery" },
  { id:110, title:"Beloved", author:"Toni Morrison", year:1987, cat:"history", price:16.00, coverImage:"covers/beloved.jpg", freeLink:"https://archive.org/details/belovednovel00morr", freeLink:"https://archive.org/details/beloved00toni/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Beloved%20Toni%20Morrison", blurb:"A former slave is haunted by the child she killed to spare from slavery. Morrison's Pulitzer masterpiece probes the unspeakable trauma of American bondage.", reason:"Slavery · Trauma · Haunting · Memory" },
  { id:111, title:"The Bluest Eye", author:"Toni Morrison", year:1970, cat:"sociology", price:16.00, coverImage:"covers/the-bluest-eye.jpg", buyLink:"https://www.amazon.com/s?k=The%20Bluest%20Eye%20Toni%20Morrison", blurb:"A Black girl prays for blue eyes, believing beauty will bring love. Morrison's devastating debut exposes how white supremacy destroys Black self-worth.", reason:"Beauty standards · Internalized racism · Childhood · Trauma" },
  { id:112, title:"Song of Solomon", author:"Toni Morrison", year:1977, cat:"history", price:16.00, coverImage:"covers/song-of-solomon.jpg", freeLink:"https://archive.org/details/song-of-solomon-toni-morrison", freeLink:"https://archive.org/details/songofsolomon0000morr/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=Song%20of%20Solomon%20Toni%20Morrison", blurb:"Milkman Dead's quest for his ancestral past becomes a mythic journey through Black American history. Morrison's soaring novel of flight, freedom, and legacy.", reason:"Black identity · Ancestry · Flight · Myth" },
  { id:113, title:"Things Fall Apart", author:"Chinua Achebe", year:1958, cat:"history", price:16.00, coverImage:"covers/things-fall-apart.jpg", freeLink:"https://archive.org/details/thingsfallapart00ache_ldx", buyLink:"https://www.amazon.com/s?k=Things%20Fall%20Apart%20Chinua%20Achebe", blurb:"Okonkwo's tragic decline mirrors the destruction of Igbo society by British colonialism. Achebe's masterpiece gave Africa its voice in world literature.", reason:"Colonialism · Igbo · Tradition · Tragedy" },
  { id:114, title:"The Satanic Verses", author:"Salman Rushdie", year:1988, cat:"politics", price:18.00, coverImage:"covers/the-satanic-verses.jpg", freeLink:"https://archive.org/details/the-satanic-verses", freeLink:"https://archive.org/details/SatanicVerses/page/n1/mode/2up", buyLink:"https://www.amazon.com/s?k=The%20Satanic%20Verses%20Salman%20Rushdie", blurb:"A fatwa was issued for this novel's alleged blasphemy. Rushdie's magical realist epic about migration, identity, and the nature of revelation.", reason:"Blasphemy · Fatwa · Migration · Magical realism" },
  { id:115, title:"The Bible", author:"Various", year:-100, cat:"philosophy", price:14.00, coverImage:"covers/the-bible.jpg", freeLink:"https://archive.org/details/creeds_of_christendom_2111_librivox", buyLink:"https://www.amazon.com/s?k=The%20Bible%20Various", blurb:"The foundational text of Western civilization, banned and burned across millennia by regimes seeking to control sacred access to divine truth.", reason:"Religion · Authority · Censorship · Scripture" },
  { id:116, title:"The Qur'an", author:"Various", year:650, cat:"philosophy", price:14.00, coverImage:"covers/the-qur-an.jpg", freeLink:"https://archive.org/details/interpretationof0000vari", freeLink:"https://www.gutenberg.org/cache/epub/2800/pg2800-images.html", buyLink:"https://www.amazon.com/s?k=The%20Qur'an%20Various", blurb:"The holy book of Islam, banned and restricted by colonial and secular authorities who feared its power to mobilize resistance and shape civilization.", reason:"Islam · Revelation · Colonialism · Scripture" }
];

let activeFilter = 'all';
const grid = document.getElementById('productGrid');

function coverHTML(b) {
    if (b.coverImage) {
      return `<div class="cover" style="padding:0;"><img src="${b.coverImage}" alt="${b.title}" style="width:100%;height:100%;object-fit:cover;display:block;border:none;"></div>`;
    }
    return `<div class="title-area">${b.title}</div><div class="author">${b.author}</div>`;
}

function renderGrid() {
  const filtered = PRODUCTS.filter(b => activeFilter === 'all' || b.cat === activeFilter);
  grid.innerHTML = filtered.map(b => `
    <div class="book" onclick="openModal(${b.id})">
      <div class="cover">${coverHTML(b)}</div>
      <div class="info">
        <div class="t">${b.title}</div>
        <div class="a">${b.author}</div>
      </div>
    </div>
  `).join('');
}

function openModal(id) {
  const b = PRODUCTS.find(x => x.id === id);
  document.getElementById('modalCover').innerHTML = coverHTML(b);
  document.getElementById('modalBody').innerHTML = `
    <div class="meta">// Case File ${String(b.id).padStart(4,'0')} · Published ${b.year}</div>
    <h2>${b.title}</h2>
    <div class="meta">by ${b.author}</div>
    <div class="blurb">${b.blurb}</div>
    <div class="why-box">
      <h5>Product Details</h5>
      <p>${b.reason}</p>
    </div>
    <div class="actions">
      ${b.buyLink ? `<button class="add" onclick="window.open('${b.buyLink}', '_blank')">BUY ON AMAZON</button>` : ''}
      ${b.freeLink ? `<button class="save" onclick="window.open('${b.freeLink}', '_blank')">GET FREE</button>` : ''}
    </div>
  `;
  document.getElementById('modalOverlay').classList.add('open');
  document.body.classList.add('lock');
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.classList.remove('lock');
}

function addToCart(id) {
  const b = PRODUCTS.find(x => x.id === id);
  showToast(`ADDED: ${b.title}`);
  closeModal();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

document.querySelectorAll('.chip').forEach(chip => {
  chip.addEventListener('click', () => {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    activeFilter = chip.dataset.filter;
    renderGrid();
  });
});

renderGrid();
</script>
</body>
</html>
